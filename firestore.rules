rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. MENU COLLECTION
    match /menu/{menuId} {
      allow read: if true;
      allow write: if true;
    }

    // 3. ORDERS COLLECTION
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // 4. TRANSACTIONS COLLECTION
    match /transactions/{txId} {
      allow read, write: if true;
    }

    // Global Catch-all safety net for undefined collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

